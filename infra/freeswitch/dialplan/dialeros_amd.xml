<include>
  <!--
    Iter 154 — AMD-conditional dispatch + sub-action routing.
    Extends iter 141 with per-outcome sub-actions read from
    channel vars set by the pacer:
      dialeros_amd_human_action
          'bridge' | 'call_menu' | 'drop'
      dialeros_amd_human_call_menu_id
          UUID, used when amd_human_action='call_menu'
      dialeros_amd_machine_action
          'voicemail' | 'audio_drop' | 'call_menu' | 'drop'
      dialeros_amd_machine_call_menu_id
          UUID, used when amd_machine_action='call_menu'
      dialeros_amd_machine_audio_path
          /var/lib/dialeros/audio/library/<id>.wav,
          used when amd_machine_action='audio_drop'

    Plus a new dialeros-audio-drop extension used by the
    top-level amd_action='audio_drop' option (ViciDial 8373).

    Earlier iters preserved (iter 139 wait_for_silence, iter 140
    channel-var overridable tuning, iter 141 post-beep recording
    trim) — those still live in dialeros-vm-drop /
    dialeros-record-and-bridge / dialeros-record-then-playback.
  -->

  <extension name="dialeros-amd-route" continue="false">
    <condition field="destination_number" expression="^dialeros-amd-route$" break="never">
      <action application="log" data="INFO [dialeros-amd] start uuid=${uuid} cid=${dialeros_correlation_id}"/>
      <action application="amd_v2" data="async:false"/>
      <action application="log" data="INFO [dialeros-amd] result=${amd_result} uuid=${uuid}"/>
      <action application="set" data="dialeros_amd_result=${amd_result}"/>
      <action application="execute_extension" data="dialeros-amd-dispatch XML default"/>
    </condition>
    <condition>
      <action application="amd_v2" data="async:false"/>
      <action application="set" data="dialeros_amd_result=${amd_result}"/>
      <action application="execute_extension" data="dialeros-amd-dispatch XML default"/>
    </condition>
  </extension>

  <!--
    Iter 154 — dispatch reads dialeros_amd_human_action /
    dialeros_amd_machine_action and routes accordingly.
    Defaults if unset (preserves iter-141 behavior):
       HUMAN   -> bridge
       MACHINE -> voicemail (existing dialeros-vm-drop path)
  -->
  <extension name="dialeros-amd-dispatch" continue="false">
    <!-- MACHINE: pick a sub-action -->
    <condition field="${amd_result}" expression="^MACHINE$" break="on-true">
      <action application="log" data="INFO [dialeros-amd] machine_path uuid=${uuid} action=${dialeros_amd_machine_action:-voicemail}"/>
      <action application="execute_extension" data="dialeros-amd-machine-action XML default"/>
    </condition>
    <!-- HUMAN / NOTSURE / UNKNOWN / empty: pick a sub-action -->
    <condition field="${amd_result}" expression="^(HUMAN|NOTSURE|UNKNOWN|)$" break="on-true">
      <action application="log" data="INFO [dialeros-amd] human_path uuid=${uuid} action=${dialeros_amd_human_action:-bridge}"/>
      <action application="execute_extension" data="dialeros-amd-human-action XML default"/>
    </condition>
  </extension>

  <!--
    Iter 154 — HUMAN-branch sub-action dispatch.
      bridge    (default) -> dialeros-record-and-bridge (iter 141)
      call_menu           -> execute_extension call_menu_<id>
      drop                -> hangup
  -->
  <extension name="dialeros-amd-human-action" continue="false">
    <condition field="${dialeros_amd_human_action}" expression="^call_menu$" break="on-true">
      <action application="log" data="INFO [dialeros-amd] human -> call_menu=${dialeros_amd_human_call_menu_id} uuid=${uuid}"/>
      <action application="execute_extension" data="call_menu_${dialeros_amd_human_call_menu_id} XML default"/>
    </condition>
    <condition field="${dialeros_amd_human_action}" expression="^drop$" break="on-true">
      <action application="log" data="INFO [dialeros-amd] human -> drop uuid=${uuid}"/>
      <action application="hangup"/>
    </condition>
    <!-- Default (no var set, or 'bridge') -->
    <condition>
      <action application="execute_extension" data="dialeros-record-and-bridge XML default"/>
    </condition>
  </extension>

  <!--
    Iter 154 — MACHINE-branch sub-action dispatch.
      voicemail  (default) -> dialeros-vm-drop  (iter 141)
      audio_drop           -> dialeros-audio-drop with machine_audio_path
      call_menu            -> execute_extension call_menu_<id>
      drop                 -> hangup
  -->
  <extension name="dialeros-amd-machine-action" continue="false">
    <condition field="${dialeros_amd_machine_action}" expression="^audio_drop$" break="on-true">
      <action application="log" data="INFO [dialeros-amd] machine -> audio_drop path=${dialeros_amd_machine_audio_path} uuid=${uuid}"/>
      <action application="set" data="dialeros_audio_drop_path=${dialeros_amd_machine_audio_path}"/>
      <action application="execute_extension" data="dialeros-audio-drop XML default"/>
    </condition>
    <condition field="${dialeros_amd_machine_action}" expression="^call_menu$" break="on-true">
      <action application="log" data="INFO [dialeros-amd] machine -> call_menu=${dialeros_amd_machine_call_menu_id} uuid=${uuid}"/>
      <action application="execute_extension" data="call_menu_${dialeros_amd_machine_call_menu_id} XML default"/>
    </condition>
    <condition field="${dialeros_amd_machine_action}" expression="^drop$" break="on-true">
      <action application="log" data="INFO [dialeros-amd] machine -> drop uuid=${uuid}"/>
      <action application="hangup"/>
    </condition>
    <!-- Default (no var set, or 'voicemail') — existing iter-141 VM-drop path -->
    <condition>
      <action application="execute_extension" data="dialeros-vm-drop XML default"/>
    </condition>
  </extension>

  <!--
    Iter 141 — common VM-drop machinery used by BOTH
    amd_action=voicemail (direct route) and amd_action=detect
    MACHINE branch when amd_machine_action='voicemail'.
  -->
  <extension name="dialeros-vm-drop" continue="false">
    <condition field="${dialeros_voicemail_path}" expression="^.+$">
      <action application="set" data="vm_silence_thresh=${dialeros_vm_silence_thresh:-256}"/>
      <action application="set" data="vm_silence_hits=${dialeros_vm_silence_hits:-25}"/>
      <action application="set" data="vm_listen_hits=${dialeros_vm_listen_hits:-4}"/>
      <action application="set" data="vm_silence_timeout=${dialeros_vm_silence_timeout:-30000}"/>
      <action application="set" data="vm_beep_grace_ms=${dialeros_vm_beep_grace_ms:-750}"/>
      <action application="log" data="INFO [dialeros-vm-drop] waiting for greeting silence uuid=${uuid}"/>
      <action application="wait_for_silence" data="${vm_silence_thresh} ${vm_silence_hits} ${vm_listen_hits} ${vm_silence_timeout}"/>
      <action application="log" data="INFO [dialeros-vm-drop] silence detected, beep-grace sleep uuid=${uuid}"/>
      <action application="sleep" data="${vm_beep_grace_ms}"/>
      <action application="execute_extension" data="dialeros-record-then-playback XML default"/>
    </condition>
    <condition>
      <action application="log" data="INFO [dialeros-vm-drop] no voicemail file configured uuid=${uuid}"/>
      <action application="hangup"/>
    </condition>
  </extension>

  <!--
    Iter 154 — Audio drop. Plays a configured .wav then hangs up.
    Used by the top-level amd_action='audio_drop' option AND by
    the detect-mode MACHINE branch when amd_machine_action='audio_drop'.
    No wait_for_silence — operators picked this when they WANT
    to talk over the answer (e.g. compliance robocall notifications).
  -->
  <extension name="dialeros-audio-drop" continue="false">
    <condition field="${dialeros_audio_drop_path}" expression="^.+$">
      <action application="log" data="INFO [dialeros-audio-drop] playing path=${dialeros_audio_drop_path} uuid=${uuid}"/>
      <action application="playback" data="${dialeros_audio_drop_path}"/>
      <action application="hangup"/>
    </condition>
    <condition>
      <action application="log" data="WARN [dialeros-audio-drop] no audio path configured uuid=${uuid}"/>
      <action application="hangup"/>
    </condition>
  </extension>

  <!--
    Iter 141 — HUMAN branch's record-then-bridge body. record_session
    starts immediately before the bridge so the saved .wav captures
    only the live conversation, not the AMD ring tone.
  -->
  <extension name="dialeros-record-and-bridge" continue="false">
    <condition field="${dialeros_recording_path}" expression="^.+$">
      <action application="log" data="INFO [dialeros-amd] starting record_session uuid=${uuid} path=${dialeros_recording_path}"/>
      <action application="set" data="RECORD_STEREO=true"/>
      <action application="record_session" data="${dialeros_recording_path}"/>
      <action application="bridge" data="${dialeros_bridge_target}"/>
    </condition>
    <condition>
      <action application="bridge" data="${dialeros_bridge_target}"/>
    </condition>
  </extension>

  <extension name="dialeros-record-then-playback" continue="false">
    <condition field="${dialeros_recording_path}" expression="^.+$">
      <action application="log" data="INFO [dialeros-vm-drop] starting post-beep record_session uuid=${uuid} path=${dialeros_recording_path}"/>
      <action application="set" data="RECORD_STEREO=true"/>
      <action application="record_session" data="${dialeros_recording_path}"/>
      <action application="playback" data="${dialeros_voicemail_path}"/>
      <action application="hangup"/>
    </condition>
    <condition>
      <action application="playback" data="${dialeros_voicemail_path}"/>
      <action application="hangup"/>
    </condition>
  </extension>
</include>
