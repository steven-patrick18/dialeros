<include>
  <!--
    Iter 68 — AMD-conditional dispatch for outbound calls.
    Iter 139 — wait_for_silence before VM drop so we don't
               talk over the machine's greeting.
    Iter 140 — five wait-for-beep params are channel-var
               overridable per campaign.
    Iter 141 — recording is now started AFTER the beep on the
               VM-drop path so the saved .wav contains only
               the dropped message, not the greeting + beep
               + message overlap. HUMAN branch starts the
               recording right before bridge so the saved
               .wav captures only the live conversation.

    The pacer originates with channel vars:
      dialeros_bridge_target    = user/1001 OR sofia/internal/...
      dialeros_voicemail_path   = /var/lib/dialeros/voicemails/<id>.wav
      dialeros_recording_path   = /var/lib/dialeros/recordings/<corr>.wav
      dialeros_amd_action       = bridge | detect | voicemail | drop
      dialeros_vm_*             = wait-for-beep tuning (iter 140)

    For amd_action=bridge the pacer still uses execute_on_answer
    record_session so the recording captures the full call from
    answer (same as iter 79 behavior). For amd_action=detect or
    voicemail the pacer SKIPS execute_on_answer and lets the
    dialplan branches below start the recording at the right
    moment.
  -->

  <extension name="dialeros-amd-route" continue="false">
    <condition field="destination_number" expression="^dialeros-amd-route$" break="never">
      <action application="log" data="INFO [dialeros-amd] start uuid=${uuid} cid=${dialeros_correlation_id}"/>
      <action application="amd_v2" data="async:false"/>
      <action application="log" data="INFO [dialeros-amd] result=${amd_result} uuid=${uuid}"/>
      <action application="set" data="dialeros_amd_result=${amd_result}"/>
      <action application="execute_extension" data="dialeros-amd-dispatch XML default"/>
    </condition>
    <condition>
      <action application="amd_v2" data="async:false"/>
      <action application="set" data="dialeros_amd_result=${amd_result}"/>
      <action application="execute_extension" data="dialeros-amd-dispatch XML default"/>
    </condition>
  </extension>

  <extension name="dialeros-amd-dispatch" continue="false">
    <condition field="${amd_result}" expression="^MACHINE$">
      <action application="log" data="INFO [dialeros-amd] machine_path uuid=${uuid} voicemail=${dialeros_voicemail_path}"/>
      <action application="execute_extension" data="dialeros-vm-drop XML default"/>
    </condition>
    <condition field="${amd_result}" expression="^(HUMAN|NOTSURE|UNKNOWN|)$">
      <action application="log" data="INFO [dialeros-amd] human_path uuid=${uuid} target=${dialeros_bridge_target}"/>
      <!--
        Iter 141 — start recording immediately before the bridge
        so the .wav captures only the live conversation. The
        pacer skips execute_on_answer record_session when
        amd_action=detect; this is the substitute.

        Recording is best-effort: when dialeros_recording_path is
        unset (admin disabled call recording in settings), the
        playback application below would normally treat
        record_session of an empty path as an error — we guard
        with a regex condition.
      -->
      <action application="execute_extension" data="dialeros-record-and-bridge XML default"/>
    </condition>
  </extension>

  <!--
    Iter 141 — common VM-drop machinery used by BOTH
    amd_action=voicemail (direct route) and amd_action=detect
    (MACHINE branch). One implementation for the
    silence-wait → grace → record → playback pattern.
  -->
  <extension name="dialeros-vm-drop" continue="false">
    <condition field="${dialeros_voicemail_path}" expression="^.+$">
      <action application="set" data="vm_silence_thresh=${dialeros_vm_silence_thresh:-256}"/>
      <action application="set" data="vm_silence_hits=${dialeros_vm_silence_hits:-25}"/>
      <action application="set" data="vm_listen_hits=${dialeros_vm_listen_hits:-4}"/>
      <action application="set" data="vm_silence_timeout=${dialeros_vm_silence_timeout:-30000}"/>
      <action application="set" data="vm_beep_grace_ms=${dialeros_vm_beep_grace_ms:-750}"/>
      <action application="log" data="INFO [dialeros-vm-drop] waiting for greeting silence uuid=${uuid}"/>
      <action application="wait_for_silence" data="${vm_silence_thresh} ${vm_silence_hits} ${vm_listen_hits} ${vm_silence_timeout}"/>
      <action application="log" data="INFO [dialeros-vm-drop] silence detected, beep-grace sleep uuid=${uuid}"/>
      <action application="sleep" data="${vm_beep_grace_ms}"/>
      <!--
        Iter 141 — start recording NOW (post-beep) so the saved
        .wav holds only the dropped message. Guarded so
        record_session isn't invoked with an empty path which
        FS treats as an error.
      -->
      <action application="execute_extension" data="dialeros-record-then-playback XML default"/>
    </condition>
    <condition>
      <action application="log" data="INFO [dialeros-vm-drop] no voicemail file configured uuid=${uuid}"/>
      <action application="hangup"/>
    </condition>
  </extension>

  <!--
    Iter 141 — start record_session conditionally + bridge.
    Split into its own extension because FreeSWITCH actions
    are sequential and we want the record_session to fire
    only when dialeros_recording_path is non-empty.
  -->
  <extension name="dialeros-record-and-bridge" continue="false">
    <condition field="${dialeros_recording_path}" expression="^.+$">
      <action application="log" data="INFO [dialeros-amd] starting record_session uuid=${uuid} path=${dialeros_recording_path}"/>
      <action application="set" data="RECORD_STEREO=true"/>
      <action application="record_session" data="${dialeros_recording_path}"/>
      <action application="bridge" data="${dialeros_bridge_target}"/>
    </condition>
    <condition>
      <!-- No recording configured: just bridge. -->
      <action application="bridge" data="${dialeros_bridge_target}"/>
    </condition>
  </extension>

  <extension name="dialeros-record-then-playback" continue="false">
    <condition field="${dialeros_recording_path}" expression="^.+$">
      <action application="log" data="INFO [dialeros-vm-drop] starting post-beep record_session uuid=${uuid} path=${dialeros_recording_path}"/>
      <action application="set" data="RECORD_STEREO=true"/>
      <action application="record_session" data="${dialeros_recording_path}"/>
      <action application="playback" data="${dialeros_voicemail_path}"/>
      <action application="hangup"/>
    </condition>
    <condition>
      <!-- No recording configured: play + hangup. -->
      <action application="playback" data="${dialeros_voicemail_path}"/>
      <action application="hangup"/>
    </condition>
  </extension>
</include>
