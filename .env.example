# DialerOS — environment variables (copy to .env or set via systemd unit)
#
# These have safe defaults baked into the code. Override here only if the
# defaults don't fit your deployment.

# Run mode. systemd unit sets this to production automatically.
NODE_ENV=production

# Admin GUI port. systemd unit sets PORT=1111.
PORT=1111

# SQLite database path. The dialeros user must own the parent dir
# with mode 0700 (bootstrap.sh handles this).
DIALEROS_DB=/opt/dialeros/apps/admin-gui/data/dialeros.db

# Master encryption key (AES-256-GCM, 32 bytes raw).
# Auto-generated on first run if missing. Back this up — without it,
# encrypted carrier passwords cannot be decrypted.
DIALEROS_MASTER_KEY_PATH=/opt/dialeros/apps/admin-gui/data/.master_key

# Provisioning runner. 'mock' emits scripted phased output without
# touching SSH; 'real' (when implemented) will spawn ansible-playbook.
# DIALEROS_RUNNER=mock
